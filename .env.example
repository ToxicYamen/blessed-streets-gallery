# Shop frontend env (Vite — only VITE_-prefixed vars are exposed to the client).

# Coming-Soon-Gate: bei "true" deckt ein Vollbild-Gate mit E-Mail-Sammlung
# (src/components/ComingSoonGate.tsx) den ganzen Shop ab.
# Bypass für interne Previews: URL mit ?vip=blessed öffnen (setzt bs-preview=1).
VITE_COMING_SOON=false
