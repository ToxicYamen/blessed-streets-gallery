# Shop frontend env (Vite — only VITE_-prefixed vars are exposed to the client).
# Copy this file to `.env.local` and fill in the real values.

# Stripe publishable key (safe to expose to the browser).
# Test mode: starts with pk_test_…  ·  Live mode: pk_live_…
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Supabase project URL (already set in the client module, kept here for reference).
# VITE_SUPABASE_URL=https://xsyjrijezdajiojxgzzr.supabase.co
# VITE_SUPABASE_ANON_KEY=…

# Coming-Soon-Gate: bei "true" deckt ein Vollbild-Gate mit E-Mail-Sammlung den Shop ab.
# Bypass für interne Previews: URL mit ?vip=blessed öffnen (setzt bs-preview=1).
VITE_COMING_SOON=false
